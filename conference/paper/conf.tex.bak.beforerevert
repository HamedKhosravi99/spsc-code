\section{Sensitivity and robustness studies}
\label{app:sensitivity}

\subsection{Probe-rate and rank-misspecification ablations}
\label{app:probe_rank_ablation}

\paragraph{Probe rate.} Sweeping probe period
$\{5,10,20,30,50,100,300\}$ at $d{=}4$, $r{=}1$, $K{=}4$, $T{=}6{,}000$
yields a U-shaped regret curve (Figure~\ref{fig:probe-ablation}) with
optimum near period $20$--$30$, matching the
$m_k^\star\propto\ell_k^{2/3}$ prediction; late-segment subspace
error is monotone in final regret, confirming that SPSC's gains trace
directly to subspace recovery quality.

\begin{figure}[!htbp]
\centering
\includegraphics[width=0.74\textwidth]{experiment3_probe_ablation.png}
\caption{Probe-rate ablation. Left: final regret vs.\ probe frequency.
Right: control regret vs.\ late-segment subspace error.}
\label{fig:probe-ablation}
\end{figure}

\paragraph{Rank misspecification (Covertype, $d{=}155$, $r^\star{=}10$).}
Sweeping specified $r\in\{1,3,5,10,15,20,30,50,80\}$ gives a U-shape:
underestimation loses signal ($+33\%$ at $r{=}1$), mild overestimation
captures residual structure (sweet spot $r{=}30$, $-10\%$ vs.\
LinUCB). SPSC beats LinUCB across $r\in[15,50]$, so mild
overestimation is a safe default. The broader approximate-rank
experiment in Table~\ref{tab:assumption_master} (sweeping orthogonal
component $\epsilon_k^\perp$) confirms this graceful-degradation
pattern at the main-text scale.

\paragraph{Empirical $d$-scaling of SPSC's probe term.}
The probe-acquisition term of Theorem~\ref{thm:spsc_regret} predicts
a $d^{2/3}$ prefactor on the regret. To check what is realised in
practice, we sweep $d\in\{10,20,30,50,70,90,110,130,160,200\}$ at
fixed $r{=}10$, $K{=}10$, $T{=}5{,}000$ on Pendigits and fit a
log-log linear model $\log\widehat R_{\mathrm{SPSC}}(d) = a\log d + b$.
The empirical exponent is $a\approx-0.16$ (Figure~\ref{fig:d-scaling}):
SPSC's total regret is approximately \emph{constant in $d$} over an
order of magnitude in $d$, well below the predicted $+0.67$ slope.
The gap indicates that on these datasets the analysis is conservative;
closing the LB/UB gap in $d$ that Theorem~\ref{thm:spsc_lb} leaves
open is a concrete avenue for future analytical work.

\begin{figure}[!htbp]
\centering
\includegraphics[width=0.95\textwidth]{experiment_d_scaling.png}
\caption{\textbf{Empirical $d$-scaling of SPSC} (Pendigits, $r{=}10$,
$K{=}10$, $T{=}5{,}000$, 5 seeds per $d$). Left: SPSC regret on log-log
axes; the empirical exponent $a\approx-0.16$ lies below the predicted
$+0.67$ slope, indicating the analysis is conservative on this
benign environment. Right: SPSC vs.\ LinUCB total regret as a function
of $d$; SPSC's advantage grows with $d$ while LinUCB's regret scales
linearly in $d$ as expected.}
\label{fig:d-scaling}
\end{figure}


